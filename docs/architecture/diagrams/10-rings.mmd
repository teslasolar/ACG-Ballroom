graph LR
    subgraph Rings["Kernel Rings · Frobenius prime spine"]
        R0["R0 Ground<br/>p=2 · 0 Hz"]
        R1["R1 Sensor<br/>p=3 · 22.1 Hz"]
        R2["R2 Gate<br/>p=5 · 40.7 Hz"]
        R3["R3 Affect<br/>p=11 · 87.5 Hz"]
        R4["R4 Exec<br/>p=31 · 285.7 Hz"]
        R5["R5 Self<br/>p=127 · 1351.5 Hz"]
        R6["R6 Observer<br/>p=709 · 11206 Hz"]
        R7["R7 Network<br/>buses A..E"]
        RB["R_BIO<br/>p=17 · 0.067 Hz"]
    end

    subgraph Buses["Bus layer A..E"]
