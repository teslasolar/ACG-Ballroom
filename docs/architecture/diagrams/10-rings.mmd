    BB --> R3
    BC --> R5
    BD --> R4
    BE --> R6

    classDef ring fill:#1e3a5f,stroke:#58a6ff,color:#c9d1d9;
    classDef bus fill:#3a3a1e,stroke:#e3b341,color:#fff8c5;
